<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- URL WCF-сервиса по умолчанию; можно переопределить в UI -->
    <add key="ServiceEndpoint" value="http://localhost:8080/SqlService" />
  </appSettings>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="SqlServiceBinding"
                 maxReceivedMessageSize="1048576"
                 receiveTimeout="00:01:00"
                 sendTimeout="00:01:00" />
      </basicHttpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
