<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <system.serviceModel>
    <!-- Конфигурация через код (Program.cs); этот раздел — для справки -->
    <bindings>
      <basicHttpBinding>
        <binding name="SqlServiceBinding"
                 maxReceivedMessageSize="1048576"
                 receiveTimeout="00:01:00"
                 sendTimeout="00:01:00"
                 openTimeout="00:00:30"
                 closeTimeout="00:00:30" />
      </basicHttpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
